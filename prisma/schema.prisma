generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrganizationStatus {
  lead
  onboarding
  active
  suspended
  archived
}

enum OrganizationRole {
  owner
  admin
  compliance_manager
  pedagogical_manager
  legal_reviewer
  viewer
}

enum EmployeeStatus {
  invited
  active
  inactive
  archived
}

enum InviteStatus {
  pending
  accepted
  expired
  revoked
}

enum CourseStatus {
  draft
  published
  archived
}

enum EnrollmentStatus {
  invited
  in_progress
  completed
  cancelled
}

enum ActivityResponseStatus {
  submitted
  feedback_ready
  needs_review
}

enum CertificateStatus {
  issued
  revoked
}

enum TeacherSubscriberStatus {
  pending
  active
  past_due
  canceled
  blocked
}

enum CommunicationKind {
  anonymous
  identified
}

enum CommunicationStatus {
  new
  triaged
  in_review
  closed
  archived
}

enum PgrStatus {
  draft
  generated
  approved
  signed
  archived
}

enum SchoolCourseEvidenceDocumentStatus {
  draft
  submitted
  reviewed
  approved
  archived
}

enum SensitiveEvidenceVaultStatus {
  intake_pending
  metadata_only
  stored_externally
  archived
  deleted_by_policy
}

enum SensitiveEvidenceAttachmentType {
  image
  audio
  video
  pdf
  other_document
}

model AdminCredential {
  id             String   @id @default("primary")
  passwordHash   String
  sessionVersion Int      @default(1)
  rotatedAt      DateTime @default(now())
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
}

model Organization {
  id               String             @id @default(cuid())
  name             String
  legalName        String?
  document         String?
  slug             String             @unique
  status           OrganizationStatus @default(onboarding)
  contractStartsAt DateTime?
  contractEndsAt   DateTime?
  employeeLimit    Int?
  stripeCustomerId String?
  metadata         Json?
  createdAt        DateTime           @default(now())
  updatedAt        DateTime           @updatedAt

  units                   Unit[]
  members                 OrganizationMember[]
  employees               Employee[]
  invitations             EmployeeInvitation[]
  enrollments             Enrollment[]
  certificates            Certificate[]
  communications          Communication[]
  pgrDocuments            PgrDocument[]
  courseEvidenceDocuments SchoolCourseEvidenceDocument[]
  sensitiveEvidenceVaultItems SchoolSensitiveEvidenceVaultItem[]
  sensitiveEvidenceAuditEvents SchoolSensitiveEvidenceAuditEvent[]
  emergencyRolesMaps      SchoolEmergencyRolesMap[]
  fireRiskWalkthroughs    SchoolFireRiskWalkthrough[]
  commercialProposals     CommercialProposal[]
  dataSubjectRequests     DataSubjectRequest[]

  @@index([status])
}

model DataSubjectRequest {
  id                    String    @id @default(cuid())
  organizationId        String?
  name                  String
  email                 String
  cpf                   String?
  requestType           String
  details               String?
  status                String    @default("pending_verification")
  verificationTokenHash String    @unique
  verificationExpiresAt DateTime
  verifiedAt            DateTime?
  completedAt           DateTime?
  deliveryEmail         String?
  exportData            Json?
  auditLog              Json?
  createdAt             DateTime  @default(now())
  updatedAt             DateTime  @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([email, status])
  @@index([createdAt])
}

model PrivacyPolicyVersion {
  id              String   @id @default(cuid())
  version         String   @unique
  title           String
  summary         String
  policyUrl       String
  publishedAt     DateTime @default(now())
  notificationLog Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  notifications PrivacyPolicyNotification[]
}

model PrivacyPolicyNotification {
  id        String    @id @default(cuid())
  versionId String
  email     String
  status    String    @default("pending")
  provider  String?
  error     String?
  sentAt    DateTime?
  createdAt DateTime  @default(now())

  version PrivacyPolicyVersion @relation(fields: [versionId], references: [id], onDelete: Cascade)

  @@unique([versionId, email])
  @@index([email, status])
}

model Unit {
  id             String   @id @default(cuid())
  organizationId String
  name           String
  city           String?
  state          String?
  isMain         Boolean  @default(false)
  metadata       Json?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employees    Employee[]

  @@index([organizationId])
}

model OrganizationMember {
  id                     String           @id @default(cuid())
  organizationId         String
  name                   String
  email                  String
  role                   OrganizationRole @default(viewer)
  receivesCommunications Boolean          @default(false)
  managesPgr             Boolean          @default(false)
  createdAt              DateTime         @default(now())
  updatedAt              DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([organizationId, role])
}

model Employee {
  id             String         @id @default(cuid())
  organizationId String
  unitId         String?
  fullName       String
  email          String?
  cpf            String?
  jobTitle       String?
  status         EmployeeStatus @default(invited)
  metadata       Json?
  createdAt      DateTime       @default(now())
  updatedAt      DateTime       @updatedAt

  organization   Organization         @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  unit           Unit?                @relation(fields: [unitId], references: [id], onDelete: SetNull)
  invitations    EmployeeInvitation[]
  enrollments    Enrollment[]
  responses      ActivityResponse[]
  certificates   Certificate[]
  communications Communication[]

  @@unique([organizationId, cpf])
  @@index([organizationId, email])
  @@index([organizationId, status])
}

model EmployeeInvitation {
  id             String       @id @default(cuid())
  organizationId String
  employeeId     String?
  email          String?
  tokenHash      String       @unique
  status         InviteStatus @default(pending)
  expiresAt      DateTime
  acceptedAt     DateTime?
  lastSentAt     DateTime?
  sendCount      Int          @default(0)
  lastSendError  String?
  createdAt      DateTime     @default(now())
  updatedAt      DateTime     @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee?    @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@index([organizationId, status])
  @@index([employeeId])
}

model Course {
  id          String       @id @default(cuid())
  slug        String       @unique
  title       String
  description String?
  status      CourseStatus @default(draft)
  metadata    Json?
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt

  lessons     Lesson[]
  enrollments Enrollment[]
  teacherCourseAccess TeacherCourseAccess[]
}

model TeacherSubscriber {
  id                   String                  @id @default(cuid())
  email                String                  @unique
  fullName             String?
  status               TeacherSubscriberStatus @default(pending)
  stripeCustomerId     String?                 @unique
  stripeSubscriptionId String?                 @unique
  currentPeriodEnd     DateTime?
  createdAt            DateTime                @default(now())
  updatedAt            DateTime                @updatedAt

  sessions     TeacherSession[]
  loginTokens  TeacherLoginToken[]
  courseAccess TeacherCourseAccess[]

  @@index([status])
}

model TeacherSession {
  id           String    @id @default(cuid())
  subscriberId String
  tokenHash    String    @unique
  expiresAt    DateTime
  revokedAt    DateTime?
  createdAt    DateTime  @default(now())

  subscriber TeacherSubscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@index([subscriberId])
  @@index([expiresAt])
}

model TeacherLoginToken {
  id           String    @id @default(cuid())
  subscriberId String?
  email        String
  tokenHash    String    @unique
  expiresAt    DateTime
  usedAt       DateTime?
  createdAt    DateTime  @default(now())

  subscriber TeacherSubscriber? @relation(fields: [subscriberId], references: [id], onDelete: Cascade)

  @@index([email])
  @@index([subscriberId])
  @@index([expiresAt])
}

model TeacherCourseAccess {
  id           String   @id @default(cuid())
  subscriberId String
  courseId     String
  grantedBy    String   @default("subscription")
  createdAt    DateTime @default(now())

  subscriber TeacherSubscriber @relation(fields: [subscriberId], references: [id], onDelete: Cascade)
  course      Course            @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@unique([subscriberId, courseId])
  @@index([subscriberId])
  @@index([courseId])
}

model Lesson {
  id         String   @id @default(cuid())
  courseId   String
  order      Int
  title      String
  videoUrl   String?
  transcript String?
  metadata   Json?
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt

  course     Course     @relation(fields: [courseId], references: [id], onDelete: Cascade)
  activities Activity[]

  @@unique([courseId, order])
  @@index([courseId])
}

model Activity {
  id        String   @id @default(cuid())
  lessonId  String
  prompt    String
  rubric    Json
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  lesson    Lesson             @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  responses ActivityResponse[]

  @@index([lessonId])
}

model Enrollment {
  id             String           @id @default(cuid())
  organizationId String
  employeeId     String
  courseId       String
  status         EnrollmentStatus @default(invited)
  startedAt      DateTime?
  completedAt    DateTime?
  createdAt      DateTime         @default(now())
  updatedAt      DateTime         @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  course       Course       @relation(fields: [courseId], references: [id], onDelete: Cascade)
  certificate  Certificate?

  @@unique([employeeId, courseId])
  @@index([organizationId, status])
}

model ActivityResponse {
  id          String                 @id @default(cuid())
  employeeId  String
  activityId  String
  answer      String
  status      ActivityResponseStatus @default(submitted)
  submittedAt DateTime               @default(now())
  metadata    Json?

  employee Employee          @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  activity Activity          @relation(fields: [activityId], references: [id], onDelete: Cascade)
  feedback ActivityFeedback?

  @@unique([employeeId, activityId])
  @@index([employeeId, status])
}

model ActivityFeedback {
  id         String   @id @default(cuid())
  responseId String   @unique
  level      String
  summary    String
  strengths  String[]
  nextSteps  String[]
  model      String?
  metadata   Json?
  createdAt  DateTime @default(now())

  response ActivityResponse @relation(fields: [responseId], references: [id], onDelete: Cascade)
}

model Certificate {
  id               String            @id @default(cuid())
  organizationId   String
  employeeId       String
  enrollmentId     String            @unique
  status           CertificateStatus @default(issued)
  verificationCode String            @unique
  issuedAt         DateTime          @default(now())
  revokedAt        DateTime?
  metadata         Json?

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee     @relation(fields: [employeeId], references: [id], onDelete: Cascade)
  enrollment   Enrollment   @relation(fields: [enrollmentId], references: [id], onDelete: Cascade)

  @@index([organizationId, issuedAt])
}

model Communication {
  id             String              @id @default(cuid())
  organizationId String
  employeeId     String?
  kind           CommunicationKind
  category       String?
  message        String
  status         CommunicationStatus @default(new)
  recipientRole  String?
  identitySealed Boolean             @default(true)
  auditHash      String?
  metadata       Json?
  createdAt      DateTime            @default(now())
  updatedAt      DateTime            @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  employee     Employee?    @relation(fields: [employeeId], references: [id], onDelete: SetNull)

  @@index([organizationId, status, createdAt])
}

model PgrDocument {
  id             String    @id @default(cuid())
  organizationId String
  status         PgrStatus @default(draft)
  formData       Json
  generatedBody  String?
  signedAt       DateTime?
  signedBy       String?
  metadata       Json?
  createdAt      DateTime  @default(now())
  updatedAt      DateTime  @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
}

model SchoolCourseEvidenceDocument {
  id             String                             @id @default(cuid())
  organizationId String
  courseSlug     String
  lessonOrder    Int
  documentKey    String
  title          String
  status         SchoolCourseEvidenceDocumentStatus @default(draft)
  content        Json
  metadata       Json?
  createdAt      DateTime                           @default(now())
  updatedAt      DateTime                           @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, courseSlug, lessonOrder, documentKey])
  @@index([organizationId, courseSlug, lessonOrder])
  @@index([organizationId, status])
}

model SchoolSensitiveEvidenceVaultItem {
  id              String                       @id @default(cuid())
  organizationId  String
  courseSlug      String
  lessonOrder     Int?
  documentKey     String
  title           String
  caseReference   String?
  sensitivity     String                       @default("restricted")
  status          SensitiveEvidenceVaultStatus @default(metadata_only)
  retentionPolicy String                       @default("contract-plus-legal-obligation-review")
  legalHold       Boolean                      @default(false)
  archivedAt      DateTime?
  archiveReason   String?
  metadata        Json?
  createdBy       String?
  updatedBy       String?
  createdAt       DateTime                     @default(now())
  updatedAt       DateTime                     @updatedAt

  organization Organization                        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  attachments  SchoolSensitiveEvidenceAttachment[]
  auditEvents  SchoolSensitiveEvidenceAuditEvent[]

  @@index([organizationId, courseSlug, documentKey])
  @@index([organizationId, status])
  @@index([organizationId, sensitivity])
  @@index([organizationId, legalHold])
}

model SchoolSensitiveEvidenceAttachment {
  id               String                          @id @default(cuid())
  organizationId   String
  vaultItemId      String
  type             SensitiveEvidenceAttachmentType
  originalFilename String
  mimeType         String
  sizeBytes        Int
  storageProvider  String?
  storageObjectKey String?
  checksumSha256   String?
  fileStatus       String                          @default("metadata_only")
  uploadedAt       DateTime?
  lastAccessedAt   DateTime?
  deletedAt        DateTime?
  deletedBy        String?
  metadata         Json?
  createdAt        DateTime                        @default(now())

  vaultItem SchoolSensitiveEvidenceVaultItem @relation(fields: [vaultItemId], references: [id], onDelete: Cascade)

  @@index([organizationId, vaultItemId])
  @@index([organizationId, type])
  @@index([organizationId, fileStatus])
}

model SchoolSensitiveEvidenceAuditEvent {
  id             String   @id @default(cuid())
  organizationId String
  vaultItemId    String?
  action         String
  actor          String
  actorRole      String?
  ipHash         String?
  userAgentHash  String?
  metadata       Json?
  createdAt      DateTime @default(now())

  organization Organization                       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  vaultItem    SchoolSensitiveEvidenceVaultItem? @relation(fields: [vaultItemId], references: [id], onDelete: SetNull)

  @@index([organizationId, createdAt])
  @@index([organizationId, action])
  @@index([vaultItemId, createdAt])
}

model SchoolEmergencyRolesMap {
  id             String @id @default(cuid())
  organizationId String
  courseSlug     String @default("incendio-escolas")
  lessonOrder    Int    @default(1)

  preventionResponsible    String?
  preventionSubstitute     String?
  preventionEvidence       String?
  preventionGaps           String?
  alertResponsible         String?
  alertSubstitute          String?
  alertEvidence            String?
  alertGaps                String?
  evacuationResponsible    String?
  evacuationSubstitute     String?
  evacuationEvidence       String?
  evacuationGaps           String?
  communicationResponsible String?
  communicationSubstitute  String?
  communicationEvidence    String?
  communicationGaps        String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, courseSlug, lessonOrder])
  @@index([organizationId])
}

model SchoolFireRiskWalkthrough {
  id             String @id @default(cuid())
  organizationId String
  courseSlug     String @default("incendio-escolas")
  lessonOrder    Int    @default(2)

  areasVisited          String?
  findingsLog           String?
  simpleCorrectionsPlan String?
  technicalReferrals    String?
  suspendedAreas        String?
  photoEvidenceNotes    String?
  reviewResponsible     String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, courseSlug, lessonOrder])
  @@index([organizationId])
}

model CommercialProposal {
  id                String   @id @default(cuid())
  organizationId    String?
  leadName          String
  leadEmail         String?
  collaboratorRange String
  billingCycle      String
  lineItems         Json
  stripeCheckoutUrl String?
  status            String   @default("draft")
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  organization Organization? @relation(fields: [organizationId], references: [id], onDelete: SetNull)

  @@index([status, createdAt])
}

model CampaignLead {
  id        String   @id @default(cuid())
  campaign  String
  source    String?
  name      String
  email     String
  phone     String
  school    String
  role      String?
  priority  String?
  status    String   @default("new")
  metadata  Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([campaign, createdAt])
  @@index([email])
  @@index([status, createdAt])
}
